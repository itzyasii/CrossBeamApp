{
  "expo": {
    "name": "CrossBeamApp",
    "slug": "crossbeam-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crossbeam.app",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "CrossBeam uses the local network to discover and connect to nearby devices for private file sharing.",
        "NSBonjourServices": [
          "_crossbeam._tcp"
        ],
        "NSPhotoLibraryUsageDescription": "CrossBeam lets you choose photos and videos to share with nearby devices.",
        "NSDocumentsFolderUsageDescription": "CrossBeam lets you choose documents to share with nearby devices.",
        "NSBluetoothAlwaysUsageDescription": "CrossBeam uses Bluetooth to discover nearby devices for file sharing."
      }
    },
    "android": {
      "package": "com.crossbeam.app",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.INTERNET",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE"
      ]
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-share-intent",
        {
          "customScheme": "crossbeamapp",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 10,
            "NSExtensionActivationSupportsMovieWithMaxCount": 10,
            "NSExtensionActivationSupportsFileWithMaxCount": 10
          }
        }
      ]
    ],
    "scheme": "crossbeamapp",
    "extra": {
      "eas": {
        "projectId": "836c5026-ba9d-4b10-b6a8-983f39238357"
      }
    }
  }
}
