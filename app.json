{
  "expo": {
    "name": "CrossBeamApp",
    "slug": "crossbeam-app",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crossbeam.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CrossBeam uses the camera to scan QR codes for device pairing.",
        "NSFaceIDUsageDescription": "CrossBeam uses FaceID to secure your transfers and privacy.",
        "NSLocalNetworkUsageDescription": "CrossBeam uses the local network to discover and connect to nearby devices for private file sharing.",
        "NSBonjourServices": [
          "_crossbeam._tcp"
        ],
        "NSPhotoLibraryUsageDescription": "CrossBeam lets you choose photos and videos to share with nearby devices.",
        "NSDocumentsFolderUsageDescription": "CrossBeam lets you choose documents to share with nearby devices.",
        "NSBluetoothAlwaysUsageDescription": "CrossBeam uses Bluetooth to discover nearby devices for file sharing."
      }
    },
    "android": {
      "package": "com.crossbeam.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.INTERNET",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "expo-camera",
      "expo-local-authentication",
      "expo-notifications",
      "expo-navigation-bar",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow CrossBeam to access your photos to share them.",
          "savePhotosPermission": "Allow CrossBeam to save shared photos to your device.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": ["audio", "photo", "video"]
        }
      ],
      [
        "expo-share-intent",
        {
          "customScheme": "crossbeamapp",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 10,
            "NSExtensionActivationSupportsMovieWithMaxCount": 10,
            "NSExtensionActivationSupportsFileWithMaxCount": 10
          }
        }
      ]
    ],
    "scheme": "crossbeamapp",
    "extra": {
      "eas": {
        "projectId": "836c5026-ba9d-4b10-b6a8-983f39238357"
      }
    }
  }
}
