{
  "name": "crossbeam-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "dev:android": "expo run:android",
    "dev:ios": "expo run:ios",
    "dev:web": "expo start --web",
    "prebuild:clean": "expo prebuild --clean",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:android:local": "eas build --platform android --local",
    "build:ios:local": "eas build --platform ios --local",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "npx expo-modules-core clean",
    "reset": "npx expo start --clear && watchman watch-del-all",
    "doctor": "npx expo-doctor",
    "ins": "npm install --legacy-peer-deps"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "axios": "^1.6.5",
    "crossbeam-native": "file:modules/crossbeam-native",
    "date-fns": "^3.0.0",
    "expo": "^55.0.24",
    "expo-blur": "~55.0.14",
    "expo-device": "~55.0.17",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-media-library": "^55.0.17",
    "expo-network": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-share-intent": "^6.1.0",
    "expo-sharing": "~55.0.19",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.12.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-vector-icons": "^10.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "~19.2.2",
    "@types/react-native": "^0.73.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^8.56.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "plugins": [
      [
        "expo-file-system"
      ]
    ]
  }
}
